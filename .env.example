# ─────────────────────────────────────────────
#  Job Prep Intelligence — Environment Config
# ─────────────────────────────────────────────

# Active LLM Provider: 'anthropic', 'openai', or 'gemini'
LLM_PROVIDER=anthropic

# 1. Anthropic API Key
#    Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# 2. Google Gemini API Key
#    Get from: https://aistudio.google.com
GEMINI_API_KEY=your-gemini-api-key-here

# 3. OpenAI API Key
#    Get from: https://platform.openai.com
OPENAI_API_KEY=sk-proj-your-key-here

# 4. Serper API Key (Optional, used for OpenAI web searches)
#    Get from: https://serper.dev
SERPER_API_KEY=your-serper-key-here

# 5. Server Port (default: 3000)
PORT=3000

# 6. Email sending via Nodemailer (Gmail SMTP)
#    For Gmail: enable 2FA → create an App Password at
#    https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-16-char-app-password

# 7. (Optional) Restrict which origins can call your server
#    Use * to allow all, or set your frontend URL
ALLOWED_ORIGIN=*

